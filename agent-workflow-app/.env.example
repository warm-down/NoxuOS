# Copy this file to .env.
# Local/offline mode uses Ollama. OpenAI remains optional.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=256
OLLAMA_CONTEXT_WINDOW=2048

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.7

DEVICE_NAME=main-laptop
DEVICE_ROLE=coordinator
PI_HOST=http://pi5.local:5000
EMPIRE_WS=ws://pi5.local:8765
EMPIRE_AUTO_RECONNECT=true
EMPIRE_RECONNECT_DELAY_MS=5000
RASPBERRY_PI_HOST=pi5.local
AI_BOX_HOST=
AI_BOX_OLLAMA_BASE_URL=
OPEN_WEBUI_URL=
OTHER_SYSTEM_HOST=
SYNCTHING_URL=
LIBRARIAN_ROOT=.
ENABLE_VOICE=false
ENABLE_TTS=false
VOICE_WAKE_WORDS=wake up,yo empire,hey empire,oi empire,hey noxu,yo noxu,my boy,what's up my boy,alpha
AGENT_WAKE_WORDS={"director":["wake up","yo empire","hey noxu","my boy"],"watchdog":["watchdog","security","kali","camera check","home security"],"writer":["writer","scribe","write this"],"reviewer":["reviewer","critic","check this"],"librarian":["librarian","files","file keeper"]}
LOCAL_VOICE_MODE=windows
LOCAL_VOICE_REQUIRE_WAKE_WORD=true
LOCAL_VOICE_MIN_CONFIDENCE=0.55
HARDWARE_APPROVAL_REQUIRED=true
STRUCTURED_LOG_PATH=logs/agents.jsonl
STRUCTURED_ERROR_LOG_PATH=logs/errors.jsonl
LOG_STACK_TRACES=false
WATCHDOG_ENABLE_NETWORK_SCAN=false
WATCHDOG_SUBNET=192.168.1

# Authorized camera sweep. Keep this limited to networks you own or administer.
SECURITY_NODE_NAME=Kali-XPS-Security
CAMERA_SCAN_SUBNET=192.168.1.0/24
CAMERA_SCAN_ALLOWED_SUBNETS=192.168.1.0/24
CAMERA_SCAN_PORTS=80,443,554,8080,8888
CAMERA_SCAN_TIMEOUT_MS=600
CAMERA_SCAN_CONCURRENCY=64
CAMERA_SWEEP_TIMEOUT_MS=90000

# Home automation integration checks.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_HOST=homeassistant.local
MQTT_HOST=homeassistant.local
MQTT_PORT=1883
ESPHOME_HOST=homeassistant.local
ESPHOME_DASHBOARD_PORT=6052
ESPHOME_API_PORT=6053

# Telegram bridge. Create a bot with @BotFather, send it a message,
# then run `npm run telegram:setup` to discover your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_ALLOW_ALL=false
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_WAKE_WORDS=wake up,yo empire,hey empire,oi empire,hey noxu,yo noxu,my boy,what's up my boy,alpha
TELEGRAM_REQUIRE_WAKE_WORD=false
TELEGRAM_VOICE_ENABLED=false
TELEGRAM_MAX_VOICE_SECONDS=120
TELEGRAM_WHISPER_COMMAND=whisper
TELEGRAM_WHISPER_MODEL=base
TELEGRAM_WHISPER_LANGUAGE=en
TELEGRAM_WHISPER_FP16=False
TELEGRAM_WHISPER_TIMEOUT_MS=120000
TELEGRAM_REPLY_AUDIO=false
TELEGRAM_TTS_MAX_CHARS=900
