# Copy this file to .env.
# Local/offline mode uses Ollama. OpenAI remains optional.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=256
OLLAMA_CONTEXT_WINDOW=2048

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.7

DEVICE_NAME=main-laptop
DEVICE_ROLE=coordinator
PI_HOST=http://pi5.local:5000
EMPIRE_WS=ws://pi5.local:8765
LIBRARIAN_ROOT=.
ENABLE_VOICE=false
ENABLE_TTS=false
HARDWARE_APPROVAL_REQUIRED=true
WATCHDOG_ENABLE_NETWORK_SCAN=false
WATCHDOG_SUBNET=192.168.1

# Telegram bridge. Create a bot with @BotFather, send it a message,
# then run `npm run telegram:setup` to discover your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_ALLOW_ALL=false
TELEGRAM_POLL_TIMEOUT_SECONDS=25
