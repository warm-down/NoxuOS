# Copy values from here into your shell or local .env files as needed.
# Do not commit real tokens.

# Use the Pi 400 IP after you find it in the router/DHCP list.
PI400_IP=192.168.1.X
HOME_ASSISTANT_URL=http://192.168.1.X:8123
HOME_ASSISTANT_HOST=192.168.1.X

# Create in Home Assistant:
# Profile -> Security -> Long-lived access tokens
HOME_ASSISTANT_TOKEN=

# Filled after add-ons/devices are installed.
MQTT_HOST=192.168.1.X
MQTT_PORT=1883
ESPHOME_HOST=192.168.1.X
ESPHOME_DASHBOARD_PORT=6052
ESPHOME_DEVICE_HOSTS=
CAMERA_HOSTS=
CAMERA_PORTS=80,443,554,8080,8888
